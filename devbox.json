{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "env": {
    "PGPORT": "5433"
  },
  "packages": {
    "cargo-deny": "0.19.9",
    "openssl": {
      "version": "3.6.0",
      "outputs": ["out", "dev"]
    },
    "pkg-config": "0.29.2",
    "pnpm": "11.9.0",
    "postgresql": "17.10",
    "pre-commit": "4.5.1",
    "rustup": "1.29.0",
    "sqlx-cli": "0.9.0"
  },
  "shell": {
    "init_hook": [
      "rustup toolchain install",
      "cargo fetch",
      "pre-commit install"
    ],
    "scripts": {
      "build-docs": "cargo doc",
      "start": "cargo run",
      "test": "cargo test -- --show-output",
      "format": "cargo fmt --all -- --check",
      "lint": "cargo clippy --workspace -- -D warnings",
      "init_db": "initdb",
      "create_db": ["dropdb --if-exists follow", "createdb follow"]
    }
  }
}
